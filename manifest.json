{
    "name": "Repro Collect",
    "short_name": "Repro Collect",
    "description": "Capture browser console logs, network traffic, CPU profiles, and screen recordings during bug reproduction.",
    "version": "1.0.0",
    "minimum_chrome_version": "109",
    "manifest_version": 3,
    "author": "yputria",
    "icons": {
        "16": "images/log/icon16.png",
        "32": "images/log/icon32.png",
        "48": "images/log/icon48.png",
        "128": "images/log/icon128.png"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_title": "Repro Collect",
        "default_popup": "popup.html"
    },
    "permissions": ["activeTab", "tabs", "debugger", "storage", "tabCapture", "offscreen", "alarms", "downloads"],
    "devtools_page": "devtools.html",
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "windows": "Ctrl+Shift+Y",
                "mac": "Command+Shift+Y",
                "chromeos": "Ctrl+Shift+U",
                "linux": "Ctrl+Shift+J"
            }
        }
    }
}
